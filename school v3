<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>MKVV School</title>

<style>

*{margin:0;padding:0;box-sizing:border-box;font-family:Arial}

body{
background:#020617;
color:white;
overflow-x:hidden;
scroll-behavior:smooth;
}

/* PARTICLE BACKGROUND */

canvas{
position:fixed;
top:0;
left:0;
z-index:-1;
}

/* NAVBAR */

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 40px;
background:rgba(0,0,0,.5);
backdrop-filter:blur(10px);
position:sticky;
top:0;
}

nav a{
margin:0 12px;
text-decoration:none;
color:white;
font-weight:bold;
}

nav a:hover{color:#38bdf8}

/* HERO */

.hero{
height:90vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
}

.hero h1{
font-size:52px;
margin-bottom:10px;
}

.hero p{
opacity:.8;
margin-bottom:20px;
}

button{
padding:10px 22px;
border:none;
border-radius:6px;
background:#38bdf8;
cursor:pointer;
}

/* GLASS CARDS */

.section{
padding:80px 20px;
text-align:center;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
gap:25px;
margin-top:40px;
}

.card{
background:rgba(255,255,255,.05);
backdrop-filter:blur(10px);
padding:30px;
border-radius:12px;
transition:.3s;
}

.card:hover{
transform:translateY(-10px);
}

/* STATS */

.stats{
display:flex;
justify-content:center;
gap:40px;
margin-top:40px;
flex-wrap:wrap;
}

.stat{
font-size:28px;
}

/* GALLERY */

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:12px;
margin-top:30px;
}

.gallery img{
width:100%;
border-radius:8px;
cursor:pointer;
}

/* MODAL */

#modal{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,.9);
justify-content:center;
align-items:center;
}

#modal img{
max-width:90%;
max-height:90%;
}

/* CHATBOT */

#chat{
position:fixed;
bottom:20px;
right:20px;
background:rgba(0,0,0,.7);
padding:15px;
border-radius:10px;
width:230px;
}

input{
width:90%;
padding:8px;
margin-top:5px;
}

footer{
text-align:center;
padding:20px;
margin-top:40px;
background:#020617;
}

</style>
</head>

<body>

<canvas id="bg"></canvas>

<header>

<h2>MKVV</h2>

<nav>
<a href="#about">About</a>
<a href="#teachers">Teachers</a>
<a href="#gallery">Gallery</a>
<a href="#portal">Portal</a>
</nav>

</header>

<section class="hero">

<h1>Madanlal Khemani Vivekananda Vidyalaya</h1>

<p>Knowledge • Character • Leadership</p>

<button onclick="scrollToAbout()">Explore</button>

</section>

<section id="about" class="section">

<h2>About MKVV</h2>

<p>A CBSE school focused on academic excellence and values.</p>

<div class="stats">

<div class="stat">
<h2 id="students">0</h2>
Students
</div>

<div class="stat">
<h2 id="teachers">0</h2>
Teachers
</div>

<div class="stat">
<h2 id="events">0</h2>
Events
</div>

</div>

</section>

<section id="teachers" class="section">

<h2>Departments</h2>

<div class="cards">

<div class="card">Mathematics</div>
<div class="card">Science</div>
<div class="card">Languages</div>
<div class="card">Computer Science</div>

</div>

</section>

<section id="gallery" class="section">

<h2>School Gallery</h2>

<div class="gallery">

<img src="https://images.unsplash.com/photo-1588072432836-e10032774350">
<img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1">
<img src="https://images.unsplash.com/photo-1509062522246-3755977927d7">

</div>

</section>

<section id="portal" class="section">

<h2>Student Portal</h2>

<input id="user" placeholder="Student ID">
<br>

<input id="pass" type="password" placeholder="Password">

<br>

<button onclick="login()">Login</button>

<p id="msg"></p>

</section>

<div id="chat">

<b>MKVV Bot 🤖</b>

<p id="bot">Ask about admissions.</p>

<input id="ask" placeholder="Type..." onkeydown="bot(event)">

</div>

<div id="modal" onclick="this.style.display='none'">
<img id="modalImg">
</div>

<footer>

<p>© MKVV School</p>
<p>Developed by Surjeetnarayan & AI Assistant</p>

</footer>

<script>

/* SMOOTH SCROLL */

function scrollToAbout(){
document.getElementById("about").scrollIntoView()
}

/* COUNTERS */

let s=0,t=0,e=0

let counter=setInterval(()=>{

s+=10
t+=1
e+=1

document.getElementById("students").innerText=s
document.getElementById("teachers").innerText=t
document.getElementById("events").innerText=e

if(s>=1200) clearInterval(counter)

},30)

/* LOGIN */

function login(){

let u=document.getElementById("user").value

document.getElementById("msg").innerText="Welcome "+u

}

/* CHATBOT */

function bot(ev){

if(ev.key==="Enter"){

let q=document.getElementById("ask").value.toLowerCase()

let r="Ask about events or admissions."

if(q.includes("admission"))
r="Admissions usually open in January."

if(q.includes("event"))
r="Annual Day and Sports Day are major events."

document.getElementById("bot").innerText=r

document.getElementById("ask").value=""

}

}

/* GALLERY MODAL */

document.querySelectorAll(".gallery img").forEach(img=>{

img.onclick=()=>{

document.getElementById("modal").style.display="flex"

document.getElementById("modalImg").src=img.src

}

})

/* PARTICLES */

let canvas=document.getElementById("bg")
let ctx=canvas.getContext("2d")

canvas.width=window.innerWidth
canvas.height=window.innerHeight

let particles=[]

for(let i=0;i<80;i++){

particles.push({
x:Math.random()*canvas.width,
y:Math.random()*canvas.height,
r:Math.random()*2
})

}

function draw(){

ctx.clearRect(0,0,canvas.width,canvas.height)

particles.forEach(p=>{

ctx.beginPath()
ctx.arc(p.x,p.y,p.r,0,Math.PI*2)
ctx.fillStyle="#38bdf8"
ctx.fill()

p.y+=0.3

if(p.y>canvas.height)p.y=0

})

requestAnimationFrame(draw)

}

draw()

</script>

</body>
</html>
